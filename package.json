{
  "name": "adfincas",
  "private": true,
  "version": "1.0.0",
  "description": "Grupo ADFincas - Administración de Fincas & Servicios Inmobiliarios",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFiles": ["./src/tests/setupEnv.js"],
    "setupFilesAfterEnv": ["./src/tests/setupTests.js"],
    "moduleNameMapper": {
      "\\.(css|less|scss|sass)$": "identity-obj-proxy",
      "\\.(jpg|jpeg|png|gif|svg|webp|avif)$": "<rootDir>/src/tests/__mocks__/fileMock.js",
      "^../assets/(.*)$": "<rootDir>/src/tests/__mocks__/fileMock.js",
      "^../../assets/(.*)$": "<rootDir>/src/tests/__mocks__/fileMock.js"
    },
    "transform": {
      "^.+\\.[jt]sx?$": "babel-jest"
    },
    "testMatch": [
      "**/tests/**/*.test.{js,jsx}",
      "**/__tests__/**/*.{js,jsx}"
    ],
    "collectCoverageFrom": [
      "src/utils/**/*.js",
      "src/data/**/*.js",
      "src/components/**/*.jsx",
      "!src/tests/**"
    ]
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/react-fontawesome": "^3.1.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-helmet-async": "^3.0.0"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-react": "^8.0.1",
    "@eslint/js": "^9.36.0",
    "@jest/globals": "^30.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "babel-jest": "^30.4.1",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.13",
    "vite": "^7.1.7"
  }
}
